# Shared local defaults for Khmer TTS Narration Studio.
# Copy service-specific values into the matching .env files when needed.

# Frontend -> Go backend
BACKEND_API_URL=http://127.0.0.1:8080
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080

# Go backend -> Python speech service
FASTAPI_TTS_URL=http://127.0.0.1:8810

# Redis queue/cache
REDIS_URL=redis://localhost:6379
QUEUE_DRIVER=redis

# Database
# Local default:
DATABASE_DRIVER=sqlite
DATABASE_DSN=reader_outputs/auth.db

# PostgreSQL example:
# DATABASE_DRIVER=postgres
# DATABASE_DSN=host=localhost user=nstudio password=nstudio dbname=nstudio port=5432 sslmode=disable TimeZone=UTC

# Local service ports
NSTUDIO_TTS_PORT=8810
NSTUDIO_BACKEND_PORT=8080
NSTUDIO_FRONTEND_PORT=3000

# Runtime device for local shell scripts.
# Use cpu on machines without a GPU.
# Use 0 for the first NVIDIA GPU, or 0,1 for multiple GPUs.
NSTUDIO_GPUS=cpu

# Speech model selection.
# Set a local model directory or a model id. Keep downloads disabled when using
# an already-downloaded local model.
# NARRATION_MODEL_ID=<model-id-or-local-path>
NSTUDIO_ALLOW_DOWNLOAD=0

# Backend generation workers
WORKER_COUNT=3
MAX_GPU_CONCURRENCY=1
MAX_CHARS_PER_CHUNK=1500
AUDIO_STORAGE_DIR=reader_outputs/audio

# Local logs
NSTUDIO_LOG_DIR=reader_outputs/narration-studio
