# Copy this to .env.khmer-tts.local for local speech-service testing.
# This file is safe to commit. Do not put secrets here.

NARRATION_MODEL_SLUG=khmer-tts
NARRATION_MODEL_NAME=Khmer-TTS

# Use a local model directory when available. If the directory does not exist,
# run with --allow-download and set this to the model id you want to download.
NARRATION_MODEL_ID=models/khmer-tts/base_model
NARRATION_LORA_WEIGHTS_PATH=

# Device selection for scripts/run_khmer_tts_local.sh.
# CPU-only:
KHMER_TTS_GPUS=cpu
# NVIDIA GPU example:
# KHMER_TTS_GPUS=0
# Multi-GPU example:
# KHMER_TTS_GPUS=0,1

NARRATION_ENABLE_GRADIO=1
KHMER_TTS_PORT=8820

# Local public demo limits
NARRATION_PUBLIC_CREDITS=2000
NARRATION_ULTIMATE_ALLOWLIST_CREDITS=1000000
NARRATION_MAX_ACTIVE_PER_IP=5
NARRATION_MAX_GENERATIONS_PER_WINDOW=10
NARRATION_ULTIMATE_ALLOWLIST_GENERATIONS=1000000
NARRATION_GENERATION_WINDOW_SECONDS=21600
